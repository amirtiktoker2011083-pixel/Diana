<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Diana Gallery</title>

<style>
    body {
        margin: 0;
        height: 100vh;
        background: url("1000041660.jpg") no-repeat center/cover;
        font-family: Arial, sans-serif;
        overflow: hidden;
    }

    .container {
        position: relative;
        width: 100%;
        height: 100%;
    }

    /* Общий стиль для окон */
    .frame {
        position: absolute;
        width: 200px;
        height: 200px;
        border: 6px solid black;
        border-radius: 10px;
        overflow: hidden;
        background: white;
    }

    .frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Позиции окон (подогнаны под твой макет) */
    .frame1 { top: 120px; left: 180px; }
    .frame2 { top: 350px; right: 150px; }
    .frame3 { bottom: 120px; left: 120px; }

    /* Зайчик */
    .bunny {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        width: 200px;
        pointer-events: none;
    }
</style>

</head>

<body>

<div class="container">

    <div class="frame frame1">
        <img src="diana1.jpg" alt="">
    </div>

    <div class="frame frame2">
        <img src="diana2.jpg" alt="">
    </div>

    <div class="frame frame3">
        <img src="diana3.jpg" alt="">
    </div>

    <!-- Зайчик без фона -->
    <img src="bunny.png" class="bunny" alt="">

</div>

</body>
</html>
